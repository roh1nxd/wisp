{
  "framework": "nextjs",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "headers": [
    {
      "source": "/workspace(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    }
  ],
  "functions": {
    "app/api/generate/route.ts": {
      "maxDuration": 60
    },
    "app/api/deploy/route.ts": {
      "maxDuration": 60
    }
  }
}
